+class GodsEyeHandler : public content::WebUIMessageHandler {
+ public:
+  explicit GodsEyeHandler(content::BrowserContext* browser_context);
+  ~GodsEyeHandler() override;
+
+  GodsEyeHandler(const GodsEyeHandler&) = delete;
+  GodsEyeHandler& operator=(const GodsEyeHandler&) = delete;
+
+  void RegisterMessages() override;
+
+ private:
+  // Returns all Gods Eye data (blocked domains/keywords, expiry, active state,
+  // user allowlist final list, pending review list). Also promotes any pending
+  // items whose 72-hour review period has elapsed.
+  void HandleGetGodsEyeData(const base::ListValue& args);
+
+  // Saves blocked domains, keywords, and expiry timestamp; activates Gods Eye.
+  void HandleSaveGodsEyeData(const base::ListValue& args);
+
+  // Adds a domain to the user-managed blocked list (while active).
+  void HandleAddDomain(const base::ListValue& args);
+
+  // Adds a keyword to the user-managed blocked list (while active).
+  void HandleAddKeyword(const base::ListValue& args);
+
+  // Removes a domain from the user-managed blocked list (while active).
+  void HandleRemoveDomain(const base::ListValue& args);
+
+  // Removes a keyword from the user-managed blocked list (while active).
+  void HandleRemoveKeyword(const base::ListValue& args);
+
+  // Adds a domain to the allowlist pending review list with current timestamp.
+  void HandleAddAllowlistDomain(const base::ListValue& args);
+
+  // Removes a domain from the final user allowlist immediately (no review).
+  void HandleRemoveAllowlistDomain(const base::ListValue& args);
+
+  // Cancels a pending allowlist review item.
+  void HandleCancelAllowlistPending(const base::ListValue& args);
+
+  // Checks pending items and promotes those whose 72-hour review has elapsed.
+  // Returns the number of items promoted.
+  int PromoteExpiredPendingItems(double now_utc);
+
+  raw_ptr<content::BrowserContext> browser_context_;
+};
+
+#endif  // CHROME_BROWSER_UI_WEBUI_GODS_EYE_GODS_EYE_HANDLER_H_
