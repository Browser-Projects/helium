+</div>
+<script>
+'use strict';
+
+// ===== Debug log helpers =====
+function dbgLog(level, msg) {
+  try {
+    var el = document.getElementById('debug-log');
+    if (!el) return;
+    var ts = new Date().toISOString().substr(11, 12);
+    el.textContent += '[' + ts + '][' + level + '] ' + msg + '\n';
+    el.scrollTop = el.scrollHeight;
+  } catch (_) {}
+}
+function toggleDebug() {
+  var el = document.getElementById('debug-log');
+  var btn = document.getElementById('debug-toggle');
+  if (el.style.display === 'none' || !el.style.display) {
+    el.style.display = 'block';
+    btn.textContent = 'Hide debug log';
+  } else {
+    el.style.display = 'none';
+    btn.textContent = 'Show debug log';
+  }
+}
+window.addEventListener('error', function(e) {
+  dbgLog('ERROR', (e.message || e) + ' at ' + (e.filename || '?') + ':' + (e.lineno || '?'));
+});
+window.addEventListener('unhandledrejection', function(e) {
+  var r = e.reason;
+  dbgLog('REJECT', String(r && (r.stack || r.message || r) || e));
+});
+(function() {
+  var orig = { error: console.error, warn: console.warn, log: console.log };
+  console.error = function() { dbgLog('error', Array.prototype.join.call(arguments, ' ')); orig.error.apply(console, arguments); };
+  console.warn  = function() { dbgLog('warn',  Array.prototype.join.call(arguments, ' ')); orig.warn.apply(console, arguments); };
+  console.log   = function() { dbgLog('log',   Array.prototype.join.call(arguments, ' ')); orig.log.apply(console, arguments); };
+})();
+
+// ===== cr.sendWithPromise shim =====
+// This page is served via a custom WebUIDataSource (not build_webui), so the
+// chrome://resources/js/cr.js module is not imported. We reimplement the small
+// public surface here so existing C++ ResolveJavascriptCallback (which calls
+// "cr.webUIResponse") and our handler.RegisterMessageCallback flow works.
+window.cr = {
+  _resolvers: {},
+  _uid: 1,
+  sendWithPromise: function(method) {
+    var args = Array.prototype.slice.call(arguments, 1);
+    var id = method + '_' + (this._uid++);
+    var self = this;
+    return new Promise(function(resolve, reject) {
+      self._resolvers[id] = { resolve: resolve, reject: reject };
+      try {
+        chrome.send(method, [id].concat(args));
+      } catch (e) {
+        delete self._resolvers[id];
+        dbgLog('SEND_ERR', method + ': ' + (e && e.message || e));
+        reject(e);
+      }
+    });
+  },
+  webUIResponse: function(id, isSuccess, response) {
+    var r = this._resolvers[id];
+    if (!r) {
+      dbgLog('WUI_MISS', id);
+      return;
+    }
+    delete this._resolvers[id];
+    if (isSuccess) r.resolve(response); else r.reject(response);
+  }
+};
+
+var TIME_API = 'https://timeapi.io/api/time/current/zone?timeZone=UTC';
+var state = { domains: [], keywords: [], expiryTimestamp: 0, active: false, nowUtc: 0, userAllowedDomains: [], allowlistPending: [] };
+
+function fmt(ts) {
+  return ts ? new Date(ts * 1000).toLocaleString() : '';
+}
+function daysLeft(expiry, now) {
+  var d = expiry - now;
+  return d > 0 ? Math.ceil(d / 86400) : 0;
+}
+async function fetchUtc() {
+  try {
+    var r = await fetch(TIME_API);
+    var d = await r.json();
+    return Math.floor(new Date(d.dateTime + 'Z').getTime() / 1000);
+  } catch(e) {
+    dbgLog('TIMEAPI_FAIL', String(e && e.message || e));
+    return Math.floor(Date.now() / 1000);
+  }
+}
+function renderTags(listId, items, removeFn) {
+  var el = document.getElementById(listId);
+  el.innerHTML = '';
+  if (!items.length) { el.innerHTML = '<span class="empty-hint">None added yet</span>'; return; }
+  items.forEach(function(v) {
+    var tag = document.createElement('span');
+    tag.className = 'tag' + (state.active ? ' locked' : '');
+    tag.textContent = v;
+    var btn = document.createElement('button');
+    btn.className = 'btn-remove';
+    btn.textContent = '\u00d7';
+    btn.disabled = state.active;
+    btn.title = state.active ? 'Locked until expiry' : 'Remove';
+    btn.onclick = function() { removeFn(v); };
+    tag.appendChild(btn);
+    el.appendChild(tag);
+  });
+}
+function renderStatus() {
+  var bar = document.getElementById('status-bar');
+  var txt = document.getElementById('status-text');
+  var inp = document.getElementById('expiry-input');
+  var btn = document.getElementById('save-btn');
+  var disp = document.getElementById('expiry-display');
+  if (state.active && state.expiryTimestamp > state.nowUtc) {
+    bar.className = 'status-bar active';
+    var days = daysLeft(state.expiryTimestamp, state.nowUtc);
+    txt.textContent = '\uD83D\uDD12 Restrictions active -- ' + days + ' day(s) remaining';
+    inp.disabled = true;
+    btn.textContent = '\uD83D\uDD12 Locked';
+    btn.disabled = true;
+    disp.style.display = 'block';
+    disp.textContent = 'Unlocks: ' + fmt(state.expiryTimestamp);
+  } else {
+    if (state.active) { state.active = false; state.expiryTimestamp = 0; }
+    bar.className = 'status-bar inactive';
+    txt.textContent = 'No active restrictions -- configure below and lock';
+    inp.disabled = false;
+    btn.textContent = '\uD83D\uDD12 Save & Lock';
+    btn.disabled = false;
+    disp.style.display = 'none';
+  }
+}
+async function init() {
+  try {
+    state.nowUtc = await fetchUtc();
+    document.getElementById('utc-time-display').textContent = 'Current UTC time: ' + fmt(state.nowUtc);
+    dbgLog('init', 'utc=' + state.nowUtc + ' calling getGodsEyeData');
+    var data = await cr.sendWithPromise('getGodsEyeData');
+    dbgLog('init', 'got data keys: ' + Object.keys(data).join(','));
+    state.domains = data.domains || [];
+    state.keywords = data.keywords || [];
+    state.expiryTimestamp = data.expiryTimestamp || 0;
+    state.active = data.active || false;
+    state.userAllowedDomains = data.userAllowedDomains || [];
+    state.allowlistPending = data.allowlistPending || [];
+    if (state.active && state.expiryTimestamp > 0 && state.nowUtc >= state.expiryTimestamp) {
+      state.active = false; state.expiryTimestamp = 0;
+    }
+    renderTags('domains-list', state.domains, removeDomain);
+    renderTags('keywords-list', state.keywords, removeKeyword);
+    renderAllowlist(state.userAllowedDomains, state.allowlistPending, state.nowUtc);
+    renderStatus();
+  } catch (e) {
+    dbgLog('INIT_FAIL', String(e && e.stack || e && e.message || e));
+  }
+}
+async function addDomain() {
+  try {
+    var v = document.getElementById('domain-input').value.trim().toLowerCase()
+      .replace(/^https?:\/\//, '').replace(/\/$/, '');
+    if (!v) return;
+    if (state.active) {
+      var ok = await cr.sendWithPromise('addDomain', v);
+      if (ok) { state.domains.push(v); renderTags('domains-list', state.domains, removeDomain); }
+    } else {
+      if (!state.domains.includes(v)) state.domains.push(v);
+      renderTags('domains-list', state.domains, removeDomain);
+    }
+    document.getElementById('domain-input').value = '';
+  } catch (e) {
+    dbgLog('ADD_DOMAIN_FAIL', String(e && e.stack || e && e.message || e));
+  }
+}
+async function addKeyword() {
+  try {
+    var v = document.getElementById('keyword-input').value.trim().toLowerCase();
+    if (!v) return;
+    if (state.active) {
+      var ok = await cr.sendWithPromise('addKeyword', v);
+      if (ok) { state.keywords.push(v); renderTags('keywords-list', state.keywords, removeKeyword); }
+    } else {
+      if (!state.keywords.includes(v)) state.keywords.push(v);
+      renderTags('keywords-list', state.keywords, removeKeyword);
+    }
+    document.getElementById('keyword-input').value = '';
+  } catch (e) {
+    dbgLog('ADD_KEYWORD_FAIL', String(e && e.stack || e && e.message || e));
+  }
+}
+function removeDomain(v) {
+  if (state.active) return;
+  state.domains = state.domains.filter(function(d) { return d !== v; });
+  renderTags('domains-list', state.domains, removeDomain);
+}
+function removeKeyword(v) {
+  if (state.active) return;
+  state.keywords = state.keywords.filter(function(k) { return k !== v; });
+  renderTags('keywords-list', state.keywords, removeKeyword);
+}
+async function saveData() {
+  try {
+    if (state.active) return;
+    var err = document.getElementById('save-error');
+    err.style.display = 'none';
+    var inp = document.getElementById('expiry-input');
+    if (!inp.value) { err.textContent = 'Please set an expiry date and time.'; err.style.display = 'block'; return; }
+    var ts = Math.floor(new Date(inp.value).getTime() / 1000);
+    if (ts <= state.nowUtc) { err.textContent = 'Expiry must be in the future.'; err.style.display = 'block'; return; }
+    dbgLog('save', 'sending saveGodsEyeData ts=' + ts + ' domains=' + state.domains.length + ' keywords=' + state.keywords.length);
+    var ok = await cr.sendWithPromise('saveGodsEyeData', state.domains, state.keywords, ts);
+    dbgLog('save', 'response: ' + ok);
+    if (ok) {
+      state.expiryTimestamp = ts; state.active = true;
+      renderTags('domains-list', state.domains, removeDomain);
+      renderTags('keywords-list', state.keywords, removeKeyword);
+      renderStatus();
+    } else { err.textContent = 'Failed to save. Please try again.'; err.style.display = 'block'; }
+  } catch (e) {
+    dbgLog('SAVE_FAIL', String(e && e.stack || e && e.message || e));
+    var err = document.getElementById('save-error');
+    err.textContent = 'Save failed (see debug log below for details).';
+    err.style.display = 'block';
+  }
+}
+
+// ===== ALLOWLIST FUNCTIONS =====
+var SYSTEM_HOSTS = ['accounts.google.com', 'calendar.google.com', 'chat.google.com', 'classroom.google.com', 'contacts.google.com', 'docs.google.com', 'drive.google.com', 'forms.google.com', 'groups.google.com', 'jamboard.google.com', 'keep.google.com', 'mail.google.com', 'meet.google.com', 'sheets.google.com', 'sites.google.com', 'slides.google.com', 'voice.google.com', 'workspace.google.com'];
+
+function renderAllowlist(userAllowed, pending, nowUtc) {
+  // System tags
+  var sysEl = document.getElementById('system-allowlist-tags');
+  sysEl.innerHTML = '';
+  SYSTEM_HOSTS.forEach(function(h) {
+    var t = document.createElement('span');
+    t.className = 'allowlist-system-tag';
+    t.title = 'System protected, cannot be removed';
+    t.textContent = '\u26D4 ' + h;
+    sysEl.appendChild(t);
+  });
+
+  // User final tags
+  var userEl = document.getElementById('user-allowlist-tags');
+  userEl.innerHTML = '';
+  if (!userAllowed || userAllowed.length === 0) {
+    userEl.innerHTML = '<span class="empty-hint">None added yet</span>';
+  } else {
+    userAllowed.forEach(function(d) {
+      var t = document.createElement('span');
+      t.className = 'allowlist-final-tag';
+      var text = document.createTextNode(d);
+      var btn = document.createElement('button');
+      btn.className = 'btn-remove';
+      btn.textContent = '\u00d7';
+      btn.title = 'Remove from allowlist';
+      btn.onclick = (function(domain) {
+        return function() { removeAllowlistDomain(domain); };
+      })(d);
+      t.appendChild(text);
+      t.appendChild(btn);
+      userEl.appendChild(t);
+    });
+  }
+
+  // Pending tags
+  var pendEl = document.getElementById('pending-allowlist-tags');
+  var pendLabel = document.getElementById('pending-label');
+  pendEl.innerHTML = '';
+  if (!pending || pending.length === 0) {
+    pendLabel.style.display = 'none';
+  } else {
+    pendLabel.style.display = 'block';
+    pending.forEach(function(item) {
+      var domain = item.domain || '';
+      var addedAt = item.addedAt || 0;
+      var secsLeft = addedAt + 259200 - nowUtc;
+      var hoursLeft = Math.ceil(secsLeft / 3600);
+      var label = hoursLeft > 1 ? hoursLeft + 'h remaining' : 'Activating soon';
+      var t = document.createElement('span');
+      t.className = 'allowlist-pending-tag';
+      var text = document.createTextNode(domain + ' \u2014 ' + label);
+      var btn = document.createElement('button');
+      btn.className = 'btn-remove';
+      btn.textContent = '\u00d7';
+      btn.title = 'Cancel review';
+      btn.onclick = (function(d) {
+        return function() { cancelAllowlistPending(d); };
+      })(domain);
+      t.appendChild(text);
+      t.appendChild(btn);
+      pendEl.appendChild(t);
+    });
+  }
+}
+
+async function addAllowlistDomain() {
+  try {
+    var v = document.getElementById('allowlist-input').value.trim().toLowerCase()
+      .replace(/^https?:\/\//, '').replace(/\/$/, '');
+    if (!v) return;
+    var ok = await cr.sendWithPromise('addAllowlistDomain', v);
+    if (ok) {
+      document.getElementById('allowlist-input').value = '';
+      var data = await cr.sendWithPromise('getGodsEyeData');
+      state.userAllowedDomains = data.userAllowedDomains || [];
+      state.allowlistPending = data.allowlistPending || [];
+      renderAllowlist(state.userAllowedDomains, state.allowlistPending, state.nowUtc);
+    }
+  } catch(e) { dbgLog('ADD_ALLOWLIST_FAIL', String(e && e.message || e)); }
+}
+
+async function removeAllowlistDomain(domain) {
+  try {
+    var ok = await cr.sendWithPromise('removeAllowlistDomain', domain);
+    if (ok) {
+      state.userAllowedDomains = state.userAllowedDomains.filter(function(d) { return d !== domain; });
+      renderAllowlist(state.userAllowedDomains, state.allowlistPending, state.nowUtc);
+    }
+  } catch(e) { dbgLog('REMOVE_ALLOWLIST_FAIL', String(e && e.message || e)); }
+}
+
+async function cancelAllowlistPending(domain) {
+  try {
+    var ok = await cr.sendWithPromise('cancelAllowlistPending', domain);
+    if (ok) {
+      state.allowlistPending = state.allowlistPending.filter(function(i) { return i.domain !== domain; });
+      renderAllowlist(state.userAllowedDomains, state.allowlistPending, state.nowUtc);
+    }
+  } catch(e) { dbgLog('CANCEL_PENDING_FAIL', String(e && e.message || e)); }
+}
+
+document.addEventListener('DOMContentLoaded', function() {
+  document.getElementById('allowlist-input').addEventListener('keydown', function(e) { if (e.key === 'Enter') addAllowlistDomain(); });
+  document.getElementById('domain-input').addEventListener('keydown', function(e) { if (e.key === 'Enter') addDomain(); });
+  document.getElementById('keyword-input').addEventListener('keydown', function(e) { if (e.key === 'Enter') addKeyword(); });
+  init();
+});
+</script>
+</body>
+</html>
+)GODS_EYE_HTML";
+bool ShouldHandleRequest(const std::string& path) {
+  return true;
+}
+
+void HandleRequest(const std::string& path,
+                   content::WebUIDataSource::GotDataCallback callback) {
+  std::move(callback).Run(
+      base::MakeRefCounted<base::RefCountedString>(std::string(kIndexHtml)));
+}
+
+}  // namespace
+
+HeliumGodsEyePage::HeliumGodsEyePage(content::WebUI* web_ui)
+    : WebUIController(web_ui) {
+  content::BrowserContext* browser_context =
+      web_ui->GetWebContents()->GetBrowserContext();
+  Profile* profile = Profile::FromBrowserContext(browser_context);
+  content::WebUIDataSource* source =
+      content::WebUIDataSource::CreateAndAdd(
+          profile, chrome::kHeliumGodsEyeHost);
+
+  source->SetRequestFilter(
+      base::BindRepeating(&ShouldHandleRequest),
+      base::BindRepeating(&HandleRequest));
+
+  source->DisableTrustedTypesCSP();
+  source->OverrideContentSecurityPolicy(
+      network::mojom::CSPDirectiveName::ScriptSrc,
+      "script-src 'self' 'unsafe-inline';");
+  source->OverrideContentSecurityPolicy(
+      network::mojom::CSPDirectiveName::ConnectSrc,
+      "connect-src 'self' https://timeapi.io;");
+
+  web_ui->AddMessageHandler(
+      std::make_unique<GodsEyeHandler>(browser_context));
+}
+
+HeliumGodsEyePage::~HeliumGodsEyePage() = default;
