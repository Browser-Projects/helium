+    <div class="time-note" style="margin-top:8px">
+      If any blocked keyword appears in a URL, page DOM text, page title, or
+      og:title, the page will be blocked.
+    </div>
+  </div>
+  <div class="card">
+    <div class="card-title">&#128737; Allowlist</div>
+    <div class="allowlist-section-label">System Protected (always allowed, cannot be removed)</div>
+    <div class="tag-list" id="system-allowlist-tags"></div>
+    <div class="allowlist-section-label">Your Active Allowlist</div>
+    <div class="tag-list" id="user-allowlist-tags"></div>
+    <div class="allowlist-section-label" id="pending-label" style="display:none">Under 72-Hour Review</div>
+    <div class="tag-list" id="pending-allowlist-tags"></div>
+    <div class="row" style="margin-top:14px">
+      <input type="text" id="allowlist-input" placeholder="e.g. reddit.com" />
+      <button class="btn-add" onclick="addAllowlistDomain()">Add to Allowlist</button>
