+  </div>
+</div>
+<div class="container">
+  <div id="status-bar" class="status-bar inactive">
+    <span id="status-text">No active restrictions</span>
+  </div>
+  <div class="card">
+    <div class="card-title">&#9201; Lock Duration</div>
+    <label>Set expiry date and time (your local time)</label>
+    <input type="datetime-local" id="expiry-input" />
+    <div class="time-note" id="utc-time-display">Fetching current UTC time...</div>
+    <div class="expiry-display" id="expiry-display" style="display:none"></div>
