+// Copyright 2025 The Helium Authors
+// You can use, redistribute, and/or modify this source code under
+// the terms of the GPL-3.0 license that can be found in the LICENSE file.
+
+#include "chrome/browser/ui/webui/gods_eye/gods_eye_handler.h"
+
+#include <memory>
+#include <string>
+
+#include "base/time/time.h"
+#include "base/values.h"
+#include "chrome/browser/browser_process.h"
+#include "components/helium_services/gods_eye_pref_names.h"
+#include "components/prefs/pref_service.h"
+#include "components/prefs/scoped_user_pref_update.h"
+
+namespace {
+
+// 72 hours in seconds.
+constexpr double kReviewPeriodSeconds = 72.0 * 3600.0;
+
+PrefService* GetLocalState() {
+  return g_browser_process->local_state();
+}
+
+}  // namespace
+
+GodsEyeHandler::GodsEyeHandler(content::BrowserContext* browser_context)
+    : browser_context_(browser_context) {}
+
+GodsEyeHandler::~GodsEyeHandler() = default;
+
+void GodsEyeHandler::RegisterMessages() {
+  web_ui()->RegisterMessageCallback(
+      "getGodsEyeData",
+      base::BindRepeating(&GodsEyeHandler::HandleGetGodsEyeData,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "saveGodsEyeData",
+      base::BindRepeating(&GodsEyeHandler::HandleSaveGodsEyeData,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "addDomain",
+      base::BindRepeating(&GodsEyeHandler::HandleAddDomain,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "addKeyword",
+      base::BindRepeating(&GodsEyeHandler::HandleAddKeyword,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "removeDomain",
+      base::BindRepeating(&GodsEyeHandler::HandleRemoveDomain,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "removeKeyword",
+      base::BindRepeating(&GodsEyeHandler::HandleRemoveKeyword,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "addAllowlistDomain",
+      base::BindRepeating(&GodsEyeHandler::HandleAddAllowlistDomain,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "removeAllowlistDomain",
+      base::BindRepeating(&GodsEyeHandler::HandleRemoveAllowlistDomain,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "cancelAllowlistPending",
+      base::BindRepeating(&GodsEyeHandler::HandleCancelAllowlistPending,
+                          base::Unretained(this)));
+}
+
+int GodsEyeHandler::PromoteExpiredPendingItems(double now_utc) {
+  PrefService* local_state = GetLocalState();
+  const base::ListValue& pending =
+      local_state->GetList(prefs::kGodsEyeAllowlistPending);
+
+  base::ListValue new_pending;
+  int promoted = 0;
+
+  for (const auto& item : pending) {
+    if (!item.is_dict())
+      continue;
+    const auto* domain = item.GetDict().FindString("domain");
+    const auto* added_at_val = item.GetDict().Find("addedAt");
+    if (!domain || !added_at_val || !added_at_val->is_double())
+      continue;
+    double added_at = added_at_val->GetDouble();
+    if (now_utc >= added_at + kReviewPeriodSeconds) {
+      // Promote: add to final user allowlist if not already there
+      ScopedListPrefUpdate update(local_state,
+                                  prefs::kGodsEyeUserAllowedDomains);
+      bool already = false;
+      for (const auto& existing : *update) {
+        if (existing.is_string() && existing.GetString() == *domain) {
+          already = true;
+          break;
+        }
+      }
+      if (!already) {
+        update->Append(*domain);
+      }
+      ++promoted;
+    } else {
+      // Keep in pending
+      new_pending.Append(item.Clone());
+    }
+  }
+
+  if (promoted > 0) {
+    local_state->SetList(prefs::kGodsEyeAllowlistPending,
+                         std::move(new_pending));
+  }
+  return promoted;
+}
+
+void GodsEyeHandler::HandleGetGodsEyeData(const base::ListValue& args) {
+  AllowJavascript();
+  const std::string& callback_id = args[0].GetString();
+
+  double now_utc = base::Time::Now().InSecondsFSinceUnixEpoch();
+
+  // Promote any pending items that have cleared the 72-hour review period.
+  PromoteExpiredPendingItems(now_utc);
+
+  PrefService* local_state = GetLocalState();
+
+  const base::ListValue& domains =
+      local_state->GetList(prefs::kGodsEyeBlockedDomains);
+  const base::ListValue& keywords =
+      local_state->GetList(prefs::kGodsEyeBlockedKeywords);
+  const base::ListValue& user_allowed =
+      local_state->GetList(prefs::kGodsEyeUserAllowedDomains);
+  const base::ListValue& pending =
+      local_state->GetList(prefs::kGodsEyeAllowlistPending);
+
+  base::DictValue result;
+  result.Set("domains", domains.Clone());
+  result.Set("keywords", keywords.Clone());
+  result.Set("expiryTimestamp",
+             local_state->GetDouble(prefs::kGodsEyeExpiryTimestamp));
+  result.Set("active", local_state->GetBoolean(prefs::kGodsEyeActive));
+  result.Set("userAllowedDomains", user_allowed.Clone());
+  result.Set("allowlistPending", pending.Clone());
+
+  ResolveJavascriptCallback(base::Value(callback_id), base::Value(std::move(result)));
+}
+
+void GodsEyeHandler::HandleSaveGodsEyeData(const base::ListValue& args) {
+  const std::string& callback_id = args[0].GetString();
+  const base::ListValue* domains = args[1].GetIfList();
+  const base::ListValue* keywords = args[2].GetIfList();
+  double ts = args[3].GetDouble();
+
+  if (!domains || !keywords || ts <= 0) {
+    ResolveJavascriptCallback(base::Value(callback_id), base::Value(false));
+    return;
+  }
+
+  PrefService* local_state = GetLocalState();
+  local_state->SetList(prefs::kGodsEyeBlockedDomains, domains->Clone());
+  local_state->SetList(prefs::kGodsEyeBlockedKeywords, keywords->Clone());
+  local_state->SetDouble(prefs::kGodsEyeExpiryTimestamp, ts);
+  local_state->SetBoolean(prefs::kGodsEyeActive, true);
+
+  ResolveJavascriptCallback(base::Value(callback_id), base::Value(true));
+}
+
+void GodsEyeHandler::HandleAddDomain(const base::ListValue& args) {
+  const std::string& callback_id = args[0].GetString();
+  const std::string& domain = args[1].GetString();
+
+  ScopedListPrefUpdate update(GetLocalState(),
+                              prefs::kGodsEyeBlockedDomains);
+  update->Append(domain);
+
+  ResolveJavascriptCallback(base::Value(callback_id), base::Value(true));
+}
+
+void GodsEyeHandler::HandleAddKeyword(const base::ListValue& args) {
+  const std::string& callback_id = args[0].GetString();
+  const std::string& keyword = args[1].GetString();
+
+  ScopedListPrefUpdate update(GetLocalState(),
+                              prefs::kGodsEyeBlockedKeywords);
+  update->Append(keyword);
+
+  ResolveJavascriptCallback(base::Value(callback_id), base::Value(true));
+}
+
+void GodsEyeHandler::HandleRemoveDomain(const base::ListValue& args) {
+  const std::string& callback_id = args[0].GetString();
+  const std::string& domain = args[1].GetString();
+
+  ScopedListPrefUpdate update(GetLocalState(),
+                              prefs::kGodsEyeBlockedDomains);
+  update->EraseValue(base::Value(domain));
+
+  ResolveJavascriptCallback(base::Value(callback_id), base::Value(true));
+}
+
+void GodsEyeHandler::HandleRemoveKeyword(const base::ListValue& args) {
+  const std::string& callback_id = args[0].GetString();
+  const std::string& keyword = args[1].GetString();
+
+  ScopedListPrefUpdate update(GetLocalState(),
+                              prefs::kGodsEyeBlockedKeywords);
+  update->EraseValue(base::Value(keyword));
+
+  ResolveJavascriptCallback(base::Value(callback_id), base::Value(true));
+}
+
+void GodsEyeHandler::HandleAddAllowlistDomain(const base::ListValue& args) {
+  const std::string& callback_id = args[0].GetString();
+  const std::string& domain = args[1].GetString();
+
+  if (domain.empty()) {
+    ResolveJavascriptCallback(base::Value(callback_id), base::Value(false));
+    return;
+  }
+
+  PrefService* local_state = GetLocalState();
+
+  // Don't add if already in the final allowlist.
+  const base::ListValue& final_list =
+      local_state->GetList(prefs::kGodsEyeUserAllowedDomains);
+  for (const auto& item : final_list) {
+    if (item.is_string() && item.GetString() == domain) {
+      ResolveJavascriptCallback(base::Value(callback_id), base::Value(false));
+      return;
+    }
+  }
+
+  // Don't add if already pending.
+  const base::ListValue& pending =
+      local_state->GetList(prefs::kGodsEyeAllowlistPending);
+  for (const auto& item : pending) {
+    if (!item.is_dict())
+      continue;
+    const auto* d = item.GetDict().FindString("domain");
+    if (d && *d == domain) {
+      ResolveJavascriptCallback(base::Value(callback_id), base::Value(false));
+      return;
+    }
+  }
+
+  // Add to pending with current timestamp.
+  ScopedListPrefUpdate update(local_state, prefs::kGodsEyeAllowlistPending);
+  base::DictValue entry;
+  entry.Set("domain", domain);
+  entry.Set("addedAt", base::Time::Now().InSecondsFSinceUnixEpoch());
+  update->Append(std::move(entry));
+
+  ResolveJavascriptCallback(base::Value(callback_id), base::Value(true));
+}
+
+void GodsEyeHandler::HandleRemoveAllowlistDomain(const base::ListValue& args) {
+  const std::string& callback_id = args[0].GetString();
+  const std::string& domain = args[1].GetString();
+
+  ScopedListPrefUpdate update(GetLocalState(),
+                              prefs::kGodsEyeUserAllowedDomains);
+  update->EraseValue(base::Value(domain));
+
+  ResolveJavascriptCallback(base::Value(callback_id), base::Value(true));
+}
+
+void GodsEyeHandler::HandleCancelAllowlistPending(
+    const base::ListValue& args) {
+  const std::string& callback_id = args[0].GetString();
+  const std::string& domain = args[1].GetString();
+
+  ScopedListPrefUpdate update(GetLocalState(),
+                              prefs::kGodsEyeAllowlistPending);
+  update->EraseIf([&domain](const base::Value& item) {
+    if (!item.is_dict())
+      return false;
+    const auto* d = item.GetDict().FindString("domain");
+    return d && *d == domain;
+  });
+
+  ResolveJavascriptCallback(base::Value(callback_id), base::Value(true));
+}
