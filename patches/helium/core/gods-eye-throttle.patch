@@ -0,0 +1,280 @@
+// Copyright 2025 The Helium Authors
+// You can use, redistribute, and/or modify this source code under
+// the terms of the GPL-3.0 license that can be found in the LICENSE file.
+
+#include "chrome/browser/gods_eye/gods_eye_dom_observer.h"
+
+#include <string>
+
+#include "base/functional/bind.h"
+#include "base/json/string_escape.h"
+#include "base/strings/escape.h"
+#include "base/strings/string_number_conversions.h"
+#include "base/strings/string_util.h"
+#include "base/strings/utf_string_conversions.h"
+#include "base/task/sequenced_task_runner.h"
+#include "base/time/time.h"
+#include "base/values.h"
+#include "chrome/browser/browser_process.h"
+#include "chrome/browser/gods_eye/gods_eye_allowlist.h"
+#include "chrome/browser/profiles/profile.h"
+#include "chrome/common/webui_url_constants.h"
+#include "components/helium_services/gods_eye_pref_names.h"
+#include "components/prefs/pref_service.h"
+#include "content/public/browser/browser_context.h"
+#include "content/public/browser/navigation_handle.h"
+#include "content/public/browser/page_navigator.h"
+#include "content/public/browser/render_frame_host.h"
+#include "content/public/browser/web_contents.h"
+#include "chrome/common/chrome_isolated_world_ids.h"
+#include "ui/base/page_transition_types.h"
+#include "ui/base/window_open_disposition.h"
+#include "url/gurl.h"
+
+namespace {
+
+// Returns true if the URL is one we must not scan/redirect from.
+bool IsExcludedURL(const GURL& url) {
+  if (!url.is_valid()) {
+    return true;
+  }
+  // Only scan real web content.
+  if (!url.SchemeIsHTTPOrHTTPS()) {
+    return true;
+  }
+  return false;
+}
+
+}  // namespace
+
+GodsEyeDomObserver::GodsEyeDomObserver(content::WebContents* web_contents)
+    : content::WebContentsObserver(web_contents),
+      content::WebContentsUserData<GodsEyeDomObserver>(*web_contents) {}
+
+GodsEyeDomObserver::~GodsEyeDomObserver() = default;
+
+bool GodsEyeDomObserver::IsGodsEyeActive() const {
+  PrefService* prefs =
+      g_browser_process ? g_browser_process->local_state() : nullptr;
+  if (!prefs || !prefs->GetBoolean(prefs::kGodsEyeActive)) {
+    return false;
+  }
+  double expiry = prefs->GetDouble(prefs::kGodsEyeExpiryTimestamp);
+  if (expiry <= 0.0) {
+    return false;
+  }
+  double now = base::Time::Now().InSecondsFSinceUnixEpoch();
+  if (now >= expiry) {
+    prefs->SetBoolean(prefs::kGodsEyeActive, false);
+    return false;
+  }
+  return true;
+}
+
+void GodsEyeDomObserver::DidFinishLoad(
+    content::RenderFrameHost* render_frame_host,
+    const GURL& validated_url) {
+  // Only scan the primary main frame; ignore subframes/iframes.
+  if (!render_frame_host ||
+      render_frame_host != web_contents()->GetPrimaryMainFrame()) {
+    return;
+  }
+  MaybeScanAndEnforce(render_frame_host, validated_url);
+}
+
+void GodsEyeDomObserver::DidFinishNavigation(
+    content::NavigationHandle* navigation_handle) {
+  // Catches SPA / HMR / client-side route changes (history.pushState,
+  // replaceState, hash navigations). These are renderer-initiated and bypass
+  // the navigation throttle entirely (per Chromium's threading model -- see
+  // NavigationThrottle::WillCommitWithoutUrlLoader comments). Full-document
+  // navigations are handled separately by DidFinishLoad.
+  if (!navigation_handle ||
+      !navigation_handle->IsInPrimaryMainFrame() ||
+      !navigation_handle->HasCommitted() ||
+      navigation_handle->IsErrorPage() ||
+      !navigation_handle->IsSameDocument()) {
+    return;
+  }
+  content::RenderFrameHost* rfh = web_contents()->GetPrimaryMainFrame();
+  if (!rfh) {
+    return;
+  }
+  // For same-document navigations the new URL IS the navigation; pull it
+  // from the handle rather than from the RenderFrameHost.
+  MaybeScanAndEnforce(rfh, navigation_handle->GetURL());
+}
+
+void GodsEyeDomObserver::MaybeScanAndEnforce(
+    content::RenderFrameHost* render_frame_host,
+    const GURL& url) {
+  // Skip non-web pages and internal pages.
+  if (IsExcludedURL(url)) {
+    return;
+  }
+
+  PrefService* prefs =
+      g_browser_process ? g_browser_process->local_state() : nullptr;
+  if (!prefs) {
+    return;
+  }
+
+  // Skip localhost, hardcoded allowlist, and user-added allowlist (all three
+  // bypass blocking entirely, including DOM keyword scanning).
+  if (IsGodsEyeAllowedAnywhere(prefs, url)) {
+    return;
+  }
+
+  // System profile (profile picker chrome:// pages): no enforcement. All
+  // other profile types -- regular, incognito, guest -- are subject to
+  // Gods Eye.
+  Profile* profile = Profile::FromBrowserContext(
+      web_contents()->GetBrowserContext());
+  if (!profile || profile->IsSystemProfile()) {
+    return;
+  }
+
+  if (!IsGodsEyeActive()) {
+    return;
+  }
+
+  // 1) URL-based blocked-domain check. Catches SPA route changes whose URL
+  //    moves to a fully-blocked host.
+  std::string matched_domain = GodsEyeMatchBlockedDomain(prefs, url);
+  if (!matched_domain.empty()) {
+    RedirectToRestricted("domain", matched_domain);
+    return;
+  }
+
+  // 2) URL-based keyword check. Catches the typical SPA case where the
+  //    blocked keyword appears in the URL path or fragment (e.g.
+  //    `/admin`, `#/settings`).
+  std::string matched_url_kw = GodsEyeMatchBlockedUrlKeyword(prefs, url);
+  if (!matched_url_kw.empty()) {
+    RedirectToRestricted("keyword", matched_url_kw);
+    return;
+  }
+
+  // 3) DOM keyword scan (asynchronous; result delivered to OnScanResult).
+  const base::ListValue& keywords =
+      prefs->GetList(prefs::kGodsEyeBlockedKeywords);
+  if (keywords.empty()) {
+    return;
+  }
+
+  // Build a JSON-escaped JS array literal of lowercased keywords.
+  std::string js_array = "[";
+  bool first = true;
+  for (const auto& entry : keywords) {
+    if (!entry.is_string()) {
+      continue;
+    }
+    std::string kw = base::ToLowerASCII(entry.GetString());
+    if (kw.empty()) {
+      continue;
+    }
+    std::string quoted;
+    base::EscapeJSONString(kw, /*put_in_quotes=*/true, &quoted);
+    if (!first) {
+      js_array += ",";
+    }
+    js_array += quoted;
+    first = false;
+  }
+  js_array += "]";
+
+  if (first) {  // no valid keywords
+    return;
+  }
+
+  // Inject a small JS snippet that scans body innerText + title + og:title
+  // for any of the keywords. Returns the matched keyword string, or empty.
+  std::string script =
+      "(function(){"
+      "  try {"
+      "    var keywords = " + js_array + ";"
+      "    var body = (document.body && document.body.innerText) || '';"
+      "    var title = document.title || '';"
+      "    var ogEl = document.querySelector('meta[property=\"og:title\"]');"
+      "    var og = (ogEl && ogEl.content) || '';"
+      "    var hay = (body + ' ' + title + ' ' + og).toLowerCase();"
+      "    for (var i = 0; i < keywords.length; i++) {"
+      "      try {"
+      "        var re = new RegExp('(?<![a-zA-Z0-9])' + keywords[i] + '(?![a-zA-Z0-9])');"
+      "        if (re.test(hay)) return keywords[i];"
+      "      } catch(re_err) {}"
+      "    }"
+      "    return '';"
+      "  } catch (e) { return ''; }"
+      "})()";
+
+  render_frame_host->ExecuteJavaScriptInIsolatedWorld(
+      base::UTF8ToUTF16(script),
+      base::BindOnce(&GodsEyeDomObserver::OnScanResult,
+                     weak_factory_.GetWeakPtr()),
+      ISOLATED_WORLD_ID_CHROME_INTERNAL);
+}
+
+void GodsEyeDomObserver::OnScanResult(base::Value result) {
+  if (!result.is_string()) {
+    return;
+  }
+  const std::string& matched = result.GetString();
+  if (matched.empty()) {
+    return;
+  }
+
+  // Re-validate state in case the world has moved on between scan dispatch
+  // and scan result. Prevents stale-callback redirects (e.g. the user
+  // navigated to localhost / an allowlisted site, or Gods Eye expired).
+  if (!IsGodsEyeActive()) {
+    return;
+  }
+  PrefService* prefs = g_browser_process->local_state();
+  const GURL& current_url = web_contents()->GetLastCommittedURL();
+  if (IsExcludedURL(current_url) ||
+      IsGodsEyeAllowedAnywhere(prefs, current_url)) {
+    return;
+  }
+
+  RedirectToRestricted("dom-keyword", matched);
+}
+
+void GodsEyeDomObserver::RedirectToRestricted(const std::string& reason,
+                                              const std::string& value) {
+  PrefService* prefs =
+      g_browser_process ? g_browser_process->local_state() : nullptr;
+  double expiry = prefs ? prefs->GetDouble(prefs::kGodsEyeExpiryTimestamp) : 0;
+  std::string redirect_url_str =
+      std::string(chrome::kHeliumRestrictedPageURL) +
+      "/?reason=" + base::EscapeQueryParamValue(reason, false) +
+      "&value=" + base::EscapeQueryParamValue(value, false) +
+      "&expiry=" +
+      base::NumberToString(static_cast<int64_t>(expiry));
+
+  // Use PostTask + OpenURL to avoid re-entrancy issues. The caller may be
+  // an async JS callback or a same-document navigation callback fired while
+  // the WebContents is in an arbitrary internal state.
+  content::OpenURLParams params(
+      GURL(redirect_url_str),
+      content::Referrer(),
+      WindowOpenDisposition::CURRENT_TAB,
+      ui::PAGE_TRANSITION_AUTO_TOPLEVEL,
+      /*is_renderer_initiated=*/false);
+
+  base::WeakPtr<content::WebContents> weak_wc =
+      web_contents()->GetWeakPtr();
+
+  base::SequencedTaskRunner::GetCurrentDefault()->PostTask(
+      FROM_HERE,
+      base::BindOnce(
+          [](base::WeakPtr<content::WebContents> wc,
+             content::OpenURLParams p) {
+            if (wc) {
+              wc->OpenURL(p, /*navigation_handle_callback=*/{});
+            }
+          },
+          std::move(weak_wc), std::move(params)));
+}
+
+WEB_CONTENTS_USER_DATA_KEY_IMPL(GodsEyeDomObserver);
