+// Copyright 2025 The Helium Authors
+// You can use, redistribute, and/or modify this source code under
+// the terms of the GPL-3.0 license that can be found in the LICENSE file.
+
+#ifndef CHROME_BROWSER_GODS_EYE_GODS_EYE_DOM_OBSERVER_H_
+#define CHROME_BROWSER_GODS_EYE_GODS_EYE_DOM_OBSERVER_H_
+
+#include <string>
+
+#include "base/memory/raw_ptr.h"
+#include "base/memory/weak_ptr.h"
+#include "base/values.h"
+#include "content/public/browser/web_contents_observer.h"
+#include "content/public/browser/web_contents_user_data.h"
+
+class GURL;
+
+namespace content {
+class NavigationHandle;
+class RenderFrameHost;
+class WebContents;
+}  // namespace content
+
+// Observes a WebContents and, after main-frame loads finish, scans the
+// rendered DOM (body innerText + title + og:title) for any blocked keyword
+// stored in the global Gods Eye prefs (Local State). If a match is found,
+// redirects the tab to chrome://restricted-page with the matched keyword.
+//
+// Also handles same-document navigations (history.pushState / replaceState /
+// hash changes) used by SPA frameworks like React Router / Vue Router /
+// Next.js so that Gods Eye cannot be bypassed by client-side routing.
+//
+// Applies to regular profiles, incognito, and guest sessions alike; only the
+// system profile is exempt. Localhost / 127.0.0.0/8 / ::1 are always exempt
+// regardless of user configuration (see IsGodsEyeLocalhost).
+class GodsEyeDomObserver
+    : public content::WebContentsObserver,
+      public content::WebContentsUserData<GodsEyeDomObserver> {
+ public:
+  GodsEyeDomObserver(const GodsEyeDomObserver&) = delete;
+  GodsEyeDomObserver& operator=(const GodsEyeDomObserver&) = delete;
+  ~GodsEyeDomObserver() override;
+
+  // content::WebContentsObserver:
+  void DidFinishLoad(content::RenderFrameHost* render_frame_host,
+                     const GURL& validated_url) override;
+  void DidFinishNavigation(
+      content::NavigationHandle* navigation_handle) override;
+
+ private:
+  friend class content::WebContentsUserData<GodsEyeDomObserver>;
+
+  explicit GodsEyeDomObserver(content::WebContents* web_contents);
+
+  // Returns true if Gods Eye is currently active (reads Local State).
+  bool IsGodsEyeActive() const;
+
+  // Shared enforcement entry point for both DidFinishLoad (full nav) and
+  // DidFinishNavigation (same-document SPA nav). Runs the allowlist /
+  // localhost / profile / active checks, then URL-based domain and keyword
+  // matchers, and finally injects the DOM keyword scan if nothing matched.
+  void MaybeScanAndEnforce(content::RenderFrameHost* render_frame_host,
+                           const GURL& url);
+
+  // Cancels the current page and navigates the tab to chrome://restricted-page
+  // with the given reason+value, via PostTask to avoid re-entrancy issues.
+  void RedirectToRestricted(const std::string& reason,
+                            const std::string& value);
+
+  // Called by the renderer once the injected scan script finishes.
+  void OnScanResult(base::Value result);
+
+  base::WeakPtrFactory<GodsEyeDomObserver> weak_factory_{this};
+
+  WEB_CONTENTS_USER_DATA_KEY_DECL();
+};
+
+#endif  // CHROME_BROWSER_GODS_EYE_GODS_EYE_DOM_OBSERVER_H_
