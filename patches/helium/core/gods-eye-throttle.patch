@@ -0,0 +1,177 @@
+// Copyright 2025 The Helium Authors
+// You can use, redistribute, and/or modify this source code under
+// the terms of the GPL-3.0 license that can be found in the LICENSE file.
+
+#include "chrome/browser/gods_eye/gods_eye_navigation_throttle.h"
+
+#include <memory>
+
+#include "base/strings/escape.h"
+#include "base/strings/string_number_conversions.h"
+#include "base/task/sequenced_task_runner.h"
+#include "base/time/time.h"
+#include "chrome/browser/browser_process.h"
+#include "chrome/browser/gods_eye/gods_eye_allowlist.h"
+#include "chrome/browser/profiles/profile.h"
+#include "chrome/common/webui_url_constants.h"
+#include "components/helium_services/gods_eye_pref_names.h"
+#include "components/prefs/pref_service.h"
+#include "content/public/browser/browser_context.h"
+#include "content/public/browser/navigation_handle.h"
+#include "content/public/browser/navigation_throttle_registry.h"
+#include "content/public/browser/page_navigator.h"
+#include "content/public/browser/web_contents.h"
+#include "ui/base/page_transition_types.h"
+#include "url/gurl.h"
+
+// static
+PrefService* GodsEyeNavigationThrottle::GetLocalState() {
+  return g_browser_process ? g_browser_process->local_state() : nullptr;
+}
+
+// static
+void GodsEyeNavigationThrottle::MaybeCreateAndAdd(
+    content::NavigationThrottleRegistry& registry) {
+  content::NavigationHandle& handle = registry.GetNavigationHandle();
+
+  if (!handle.IsInMainFrame())
+    return;
+
+  const GURL& url = handle.GetURL();
+  if (url.SchemeIs("chrome") &&
+      (url.host() == chrome::kHeliumRestrictedPageHost ||
+       url.host() == chrome::kHeliumGodsEyeHost)) {
+    return;
+  }
+
+  content::WebContents* wc = handle.GetWebContents();
+  if (!wc)
+    return;
+
+  // System profile (profile picker) is the only profile type exempt from
+  // Gods Eye. Regular, incognito, and guest profiles all enforce the global
+  // Gods Eye config stored in Local State.
+  Profile* profile = Profile::FromBrowserContext(wc->GetBrowserContext());
+  if (!profile || profile->IsSystemProfile())
+    return;
+
+  PrefService* prefs = GetLocalState();
+  if (!prefs || !prefs->GetBoolean(prefs::kGodsEyeActive))
+    return;
+
+  registry.AddThrottle(std::make_unique<GodsEyeNavigationThrottle>(registry));
+}
+
+GodsEyeNavigationThrottle::GodsEyeNavigationThrottle(
+    content::NavigationThrottleRegistry& registry)
+    : content::NavigationThrottle(registry) {}
+
+GodsEyeNavigationThrottle::~GodsEyeNavigationThrottle() = default;
+
+const char* GodsEyeNavigationThrottle::GetNameForLogging() {
+  return "GodsEyeNavigationThrottle";
+}
+
+GodsEyeNavigationThrottle::ThrottleCheckResult
+GodsEyeNavigationThrottle::WillStartRequest() {
+  return CheckNavigation();
+}
+
+GodsEyeNavigationThrottle::ThrottleCheckResult
+GodsEyeNavigationThrottle::WillRedirectRequest() {
+  return CheckNavigation();
+}
+
+bool GodsEyeNavigationThrottle::IsGodsEyeActive() const {
+  PrefService* prefs = GetLocalState();
+  if (!prefs || !prefs->GetBoolean(prefs::kGodsEyeActive))
+    return false;
+
+  double expiry = prefs->GetDouble(prefs::kGodsEyeExpiryTimestamp);
+  if (expiry <= 0.0)
+    return false;
+
+  double now = base::Time::Now().InSecondsFSinceUnixEpoch();
+  if (now >= expiry) {
+    prefs->SetBoolean(prefs::kGodsEyeActive, false);
+    return false;
+  }
+  return true;
+}
+
+bool GodsEyeNavigationThrottle::IsAllowedHost(const GURL& url) const {
+  // IsGodsEyeAllowedAnywhere covers: localhost (RFC 6761 + loopback IPs) +
+  // hardcoded Google Workspace allowlist + user-managed allowlist.
+  return IsGodsEyeAllowedAnywhere(GetLocalState(), url);
+}
+
+GodsEyeNavigationThrottle::ThrottleCheckResult
+GodsEyeNavigationThrottle::RedirectToRestrictedPage(
+    const std::string& reason,
+    const std::string& value) {
+  PrefService* prefs = GetLocalState();
+  double expiry = prefs ? prefs->GetDouble(prefs::kGodsEyeExpiryTimestamp) : 0;
+  std::string redirect_url_str =
+      std::string(chrome::kHeliumRestrictedPageURL) + "/?reason=" +
+      base::EscapeQueryParamValue(reason, false) + "&value=" +
+      base::EscapeQueryParamValue(value, false) + "&expiry=" +
+      base::NumberToString(static_cast<int64_t>(expiry));
+
+  // Build OpenURLParams from the current navigation handle, then override the
+  // URL. We must NOT call GetController().LoadURL() here because we are inside
+  // a NavigationThrottle callback -- doing so fires a DCHECK in Chromium's
+  // navigation machinery. Instead, schedule the new navigation asynchronously
+  // so it executes after the throttle stack has fully unwound.
+  content::OpenURLParams params =
+      content::OpenURLParams::FromNavigationHandle(navigation_handle());
+  params.url = GURL(redirect_url_str);
+  params.transition = ui::PAGE_TRANSITION_AUTO_TOPLEVEL;
+  params.is_renderer_initiated = false;
+
+  base::WeakPtr<content::WebContents> weak_wc =
+      navigation_handle()->GetWebContents()->GetWeakPtr();
+
+  base::SequencedTaskRunner::GetCurrentDefault()->PostTask(
+      FROM_HERE,
+      base::BindOnce(
+          [](base::WeakPtr<content::WebContents> wc,
+             content::OpenURLParams p) {
+            if (wc)
+              wc->OpenURL(p, /*navigation_handle_callback=*/{});
+          },
+          std::move(weak_wc), std::move(params)));
+
+  // CANCEL_AND_IGNORE: stop the original navigation and pretend it never
+  // happened; the PostTask above will navigate to the restricted page.
+  return CANCEL_AND_IGNORE;
+}
+
+GodsEyeNavigationThrottle::ThrottleCheckResult
+GodsEyeNavigationThrottle::CheckNavigation() {
+  // Promote any user-allowlist entries whose 36h review window has elapsed,
+  // so that allow rules take effect even if the user never opens the Gods
+  // Eye settings page after the deadline.
+  GodsEyePromoteExpiredPendingAllowlist(GetLocalState());
+
+  if (!IsGodsEyeActive())
+    return PROCEED;
+
+  const GURL& url = navigation_handle()->GetURL();
+
+  // Localhost + hardcoded + user allowlist: always allow regardless of
+  // block lists.
+  if (IsAllowedHost(url))
+    return PROCEED;
+
+  std::string matched_domain =
+      GodsEyeMatchBlockedDomain(GetLocalState(), url);
+  if (!matched_domain.empty())
+    return RedirectToRestrictedPage("domain", matched_domain);
+
+  std::string matched_keyword =
+      GodsEyeMatchBlockedUrlKeyword(GetLocalState(), url);
+  if (!matched_keyword.empty())
+    return RedirectToRestrictedPage("keyword", matched_keyword);
+
+  return PROCEED;
+}
