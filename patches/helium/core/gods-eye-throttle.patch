+// Copyright 2025 The Helium Authors
+// You can use, redistribute, and/or modify this source code under
+// the terms of the GPL-3.0 license that can be found in the LICENSE file.
+
+#ifndef CHROME_BROWSER_GODS_EYE_GODS_EYE_ALLOWLIST_H_
+#define CHROME_BROWSER_GODS_EYE_GODS_EYE_ALLOWLIST_H_
+
+#include <string>
+#include <string_view>
+
+#include "base/strings/string_util.h"
+#include "net/base/url_util.h"
+#include "url/gurl.h"
+
+class PrefService;
+
+// Hard-coded allowlist of domains that always bypass Gods Eye blocking.
+// These cannot be modified by the user. Covers Google Workspace productivity
+// tools but deliberately excludes google.com (search).
+inline constexpr const char* kGodsEyeAllowedHosts[] = {
+    "accounts.google.com",    // Auth -- required for all Google sign-ins
+    "calendar.google.com",
+    "chat.google.com",
+    "classroom.google.com",
+    "contacts.google.com",
+    "docs.google.com",
+    "drive.google.com",
+    "forms.google.com",
+    "groups.google.com",
+    "jamboard.google.com",
+    "keep.google.com",
+    "mail.google.com",
+    "meet.google.com",
+    "sheets.google.com",
+    "sites.google.com",
+    "slides.google.com",
+    "voice.google.com",
+    "workspace.google.com",
+};
+
+// Returns true if |url| matches any entry in the hardcoded allowlist.
+// Comparison is case-insensitive; leading "www." is stripped before matching.
+// Whitelisted domains bypass ALL Gods Eye blocking (domain, keyword, and DOM).
+inline bool IsGodsEyeAllowedHost(const GURL& url) {
+  if (!url.has_host()) {
+    return false;
+  }
+  std::string host(url.host());
+  if (base::StartsWith(host, "www.", base::CompareCase::INSENSITIVE_ASCII)) {
+    host = host.substr(4);
+  }
+  for (const char* allowed : kGodsEyeAllowedHosts) {
+    if (base::EqualsCaseInsensitiveASCII(host, allowed)) {
+      return true;
+    }
+  }
+  return false;
+}
+
+// Returns true if |url|'s host is a loopback / localhost address (per RFC
+// 6761): "localhost", "*.localhost", 127.0.0.0/8, ::1. Local development
+// servers are unconditionally exempt from Gods Eye so that the feature
+// cannot interfere with engineering work. This is a hard-coded exemption
+// not exposed to the user (localhost is not a valid public domain).
+inline bool IsGodsEyeLocalhost(const GURL& url) {
+  return net::IsLocalhost(url);
+}
+
+// Returns true if |url|'s host matches any entry in the user-managed allowlist
+// stored in Local State (kGodsEyeUserAllowedDomains). Match is exact-host only
+// (no subdomain inheritance) after lowercasing and stripping leading "www.".
+bool IsGodsEyeUserAllowedDomain(PrefService* local_state, const GURL& url);
+
+// Convenience: returns true if |url| is allowed by localhost exemption, the
+// hardcoded list, or the user-managed allowlist. All three bypass ALL Gods
+// Eye blocking (domain, keyword, and DOM keyword).
+inline bool IsGodsEyeAllowedAnywhere(PrefService* local_state,
+                                     const GURL& url) {
+  return IsGodsEyeLocalhost(url) ||
+         IsGodsEyeAllowedHost(url) ||
+         IsGodsEyeUserAllowedDomain(local_state, url);
+}
+
+// Shared blocked-domain matcher. Returns the matched pattern (as stored in
+// prefs, post-www-strip) or an empty string if no match. Used by both the
+// navigation throttle and the DOM observer.
+std::string GodsEyeMatchBlockedDomain(PrefService* local_state,
+                                      const GURL& url);
+
+// Shared blocked-keyword matcher operating on |url|.spec(). Returns the
+// matched keyword (as stored in prefs) or an empty string.
+std::string GodsEyeMatchBlockedUrlKeyword(PrefService* local_state,
+                                          const GURL& url);
+
+// Walks kGodsEyeAllowlistPending and promotes any entries whose 36-hour review
+// window has elapsed into kGodsEyeUserAllowedDomains. Safe to call from any
+// UI-thread context (PrefService is UI-thread-affine). Cheap if pending list
+// is empty.
+void GodsEyePromoteExpiredPendingAllowlist(PrefService* local_state);
+
+// 36 hours in seconds. Exposed for unit tests / WebUI countdown reuse.
+inline constexpr double kGodsEyeAllowlistReviewSeconds = 36.0 * 60.0 * 60.0;
+
+#endif  // CHROME_BROWSER_GODS_EYE_GODS_EYE_ALLOWLIST_H_
