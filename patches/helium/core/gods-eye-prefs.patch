@@ -1679,6 +1681,14 @@
       policy::policy_prefs::kLocalNetworkAccessPermissionsPolicyDefaultEnabled,
       false);
 
+  // Gods Eye feature prefs -- in local_state to share across all profiles.
+  registry->RegisterListPref(prefs::kGodsEyeBlockedDomains);
+  registry->RegisterListPref(prefs::kGodsEyeBlockedKeywords);
+  registry->RegisterDoublePref(prefs::kGodsEyeExpiryTimestamp, 0.0);
+  registry->RegisterBooleanPref(prefs::kGodsEyeActive, false);
+  registry->RegisterListPref(prefs::kGodsEyeUserAllowedDomains);
+  registry->RegisterListPref(prefs::kGodsEyeAllowlistPending);
+
   // This is intentionally last.
   RegisterLocalStatePrefsForMigration(registry);
